{
  "name": "@sketchapedia/server-gateway",
  "version": "0.0.0",
  "description": "WebSocket entry gateway (Bun + Hono) — terminates client transport, authenticates, fans out to orchestrator.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Sketchapedia contributors",
  "homepage": "https://github.com/nirholas/sketchapedia/tree/main/packages/server-gateway",
  "repository": {
    "type": "git",
    "url": "https://github.com/nirholas/sketchapedia.git",
    "directory": "packages/server-gateway"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "CHANGELOG.md"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "biome check src",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo .typecheck coverage *.tsbuildinfo"
  },
  "dependencies": {
    "@sketchapedia/protocol": "workspace:*"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vitest": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@biomejs/biome": "catalog:",
    "rimraf": "catalog:",
    "@types/node": "catalog:",
    "tsup": "catalog:"
  }
}
