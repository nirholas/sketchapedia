{
  "name": "@sketchapedia/protocol",
  "version": "0.0.0",
  "description": "Shared wire-protocol types and message schemas for Sketchapedia.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Sketchapedia contributors",
  "homepage": "https://github.com/nirholas/sketchapedia/tree/main/packages/protocol",
  "repository": {
    "type": "git",
    "url": "https://github.com/nirholas/sketchapedia.git",
    "directory": "packages/protocol"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "CHANGELOG.md"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "biome check src",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo .typecheck coverage *.tsbuildinfo"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vitest": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@biomejs/biome": "catalog:",
    "rimraf": "catalog:",
    "@types/node": "catalog:",
    "tsup": "catalog:"
  }
}
