# =============================================================================
# Environment configuration for @sketchapedia/tests-e2e
# Copy to `.env` for local runs, or surface these as CI secrets. Every variable
# here is read in fixtures/environment.ts (zod-validated at startup).
# =============================================================================

# ---- Stack endpoints (read by the browser under test) -----------------------
E2E_GATEWAY_HTTP_URL=http://localhost:8080
E2E_GATEWAY_WS_URL=ws://localhost:8080/ws
E2E_CACHE_ADMIN_URL=http://localhost:8090
E2E_COLLECTOR_URL=http://localhost:4318

# ---- Reference app URLs -----------------------------------------------------
E2E_EIFFEL_URL=http://localhost:3001
E2E_ICE_WATER_URL=http://localhost:3002
E2E_TIMES_SQUARE_URL=http://localhost:3003
E2E_DASHBOARD_URL=http://localhost:3004

# ---- Tenant identity --------------------------------------------------------
E2E_TENANT_ID=tenant-e2e
E2E_USER_ID=user-e2e
E2E_USER_ROLES=user

# ---- JWT signing (tests mint tokens locally) --------------------------------
# Prefer private/public PEMs; set E2E_JWT to override with a precomputed token.
E2E_JWT_ISSUER=sketchapedia-test
E2E_JWT_AUDIENCE=sketchapedia-gateway
# E2E_JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# E2E_JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"
# E2E_JWT=<precomputed-token>

# ---- Cache admin ------------------------------------------------------------
E2E_CACHE_ADMIN_TOKEN=e2e-admin

# ---- Model access (orchestrator container) ---------------------------------
# Provisioned in a dedicated Modal test workspace; CI reads from GitHub secrets.
MODAL_API_KEY=
MODAL_WORKSPACE=sketchapedia-test
IMAGE_MODEL_ENDPOINT=
LAYOUT_MODEL_ENDPOINT=

# ---- Profile ----------------------------------------------------------------
# One of: light | nightly | weekend
E2E_PROFILE=light
# Set to 1 to include tests whose title matches an active quarantine entry.
E2E_INCLUDE_QUARANTINED=0
