    "clean": "rimraf dist .turbo .typecheck coverage playwright-report test-results *.tsbuildinfo"
  },
  "dependencies": {
    "@sketchapedia/client-core": "workspace:*",
    "@sketchapedia/client-react": "workspace:*",
    "@sketchapedia/protocol": "workspace:*"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vitest": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@biomejs/biome": "catalog:",
    "rimraf": "catalog:",
    "@types/node": "catalog:",
    "@playwright/test": "^1.49.1"
  }
}
