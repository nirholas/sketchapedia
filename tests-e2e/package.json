{
  "name": "@sketchapedia/tests-e2e",
  "version": "0.0.0",
  "description": "Playwright end-to-end suite exercising the client SDK against reference apps.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Sketchapedia contributors",
  "homepage": "https://github.com/nirholas/sketchapedia/tree/main/root/tests-e2e",
  "repository": {
    "type": "git",
    "url": "https://github.com/nirholas/sketchapedia.git",
    "directory": "root/tests-e2e"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vitest run --coverage",
    "test:e2e": "playwright test",
